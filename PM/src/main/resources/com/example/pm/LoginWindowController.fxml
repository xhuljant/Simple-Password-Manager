<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pm.Controller.LoginWindowController">
   <children>
      <ImageView fitHeight="151.0" fitWidth="161.0" layoutX="228.0" layoutY="14.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../Media/lock.png" />
         </image>
      </ImageView>
      <TextField fx:id="userNameField" layoutX="184.0" layoutY="193.0" prefHeight="25.0" prefWidth="239.0" promptText="User Name" />
      <PasswordField fx:id="passwordField" layoutX="184.0" layoutY="226.0" prefHeight="26.0" prefWidth="239.0" promptText="Password" />
      <Button id="loginButton" layoutX="184.0" layoutY="264.0" mnemonicParsing="false" onAction="#handleLoginButton" prefHeight="45.0" prefWidth="239.0" text="Login" textAlignment="CENTER">
         <font>
            <Font size="23.0" />
         </font>
      </Button>
      <Button layoutX="184.0" layoutY="352.0" mnemonicParsing="false" onAction="#handleCreateAccountButton" prefHeight="34.0" prefWidth="239.0" text="Create New Account" />
      <Button fx:id="importButton" layoutX="536.0" layoutY="361.0" mnemonicParsing="false" onAction="#handleImportButton" prefHeight="25.0" text="Import" />
   </children>
</AnchorPane>
