<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="416.0" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.pm.Controller.CreateAccountController">
   <children>
      <TextField id="userNameField" fx:id="userNameField" layoutX="88.0" layoutY="114.0" prefHeight="26.0" prefWidth="240.0" promptText="Username" />
      <PasswordField fx:id="passwordField" layoutX="88.0" layoutY="187.0" prefHeight="26.0" prefWidth="240.0" promptText="Password" />
      <PasswordField fx:id="retypedPasswordField" layoutX="88.0" layoutY="228.0" prefHeight="26.0" prefWidth="240.0" promptText="Retype Password" />
      <Button id="createAccountButton" defaultButton="true" layoutX="220.0" layoutY="331.0" mnemonicParsing="false" onAction="#handleCreateAccountButton" prefHeight="49.0" prefWidth="108.0" text="Create Account" textAlignment="CENTER" />
      <Button id="generatePasswordButton" contentDisplay="RIGHT" layoutX="92.0" layoutY="331.0" mnemonicParsing="false" onAction="#handleGeneratePasswordButton" prefHeight="49.0" prefWidth="108.0" text="Generate Password" textAlignment="CENTER" wrapText="true" />
      <ImageView fitHeight="85.0" fitWidth="200.0" layoutX="166.0" layoutY="14.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../Media/lock.png" />
         </image>
      </ImageView>
      <Text layoutX="92.0" layoutY="275.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Your password must be at least 8 characters long and include at least one letter, one number, and one special character." wrappingWidth="240.0">
         <font>
            <Font size="11.0" />
         </font>
      </Text>
      <Text layoutX="92.0" layoutY="158.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Each username must be unique and cannot be associated with more than one account" wrappingWidth="240.0">
         <font>
            <Font size="11.0" />
         </font>
      </Text>
   </children>
</AnchorPane>
